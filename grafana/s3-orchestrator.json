{
  "uid": "s3-orchestrator",
  "title": "S3 Orchestrator",
  "tags": ["s3-orchestrator", "storage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Build Info",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "s3proxy_build_info",
          "legendFormat": "{{version}}",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Total Requests",
      "gridPos": { "x": 4, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(s3proxy_manager_requests_total)",
          "legendFormat": "Total"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Request Rate",
      "gridPos": { "x": 9, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(s3proxy_manager_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Error Rate",
      "gridPos": { "x": 14, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(s3proxy_manager_requests_total{status=\"error\"}[5m]))",
          "legendFormat": "errors/s"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Inflight Requests",
      "gridPos": { "x": 19, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(s3proxy_inflight_requests)",
          "legendFormat": "inflight"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "id": 7,
      "title": "Quota & Storage",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "gauge",
      "id": 8,
      "title": "Quota Usage",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (backend) (s3proxy_quota_bytes_used) / max by (backend) (s3proxy_quota_bytes_limit) * 100",
          "legendFormat": "{{backend}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "type": "table",
      "id": 9,
      "title": "Total Objects",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (backend) (s3proxy_objects_count)",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "backend", "desc": false }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "Value": "Objects" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Objects" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [{ "color": "blue", "value": null }]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "id": 10,
      "title": "Available Space",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (backend) (s3proxy_quota_bytes_available)",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "backend", "desc": false }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "Value": "Available" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Available" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 536870912 },
                    { "color": "green", "value": 1073741824 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Quota Usage Over Time",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (backend) (s3proxy_quota_bytes_used)",
          "legendFormat": "{{backend}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "row",
      "id": 12,
      "title": "Request Performance",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Request Rate by Method",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (operation, status) (rate(s3proxy_manager_requests_total[5m]))",
          "legendFormat": "{{operation}} {{status}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "Request Duration (p50 / p95 / p99)",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(s3proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(s3proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(s3proxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 15,
      "title": "Request / Response Size",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(s3proxy_request_size_bytes_sum[5m]))",
          "legendFormat": "Request (upload)"
        },
        {
          "expr": "sum(rate(s3proxy_response_size_bytes_sum[5m]))",
          "legendFormat": "Response (download)"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "row",
      "id": 16,
      "title": "Backend Operations",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 17,
      "title": "Backend Request Rate",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (operation, backend, status) (rate(s3proxy_backend_requests_total[5m]))",
          "legendFormat": "{{backend}} {{operation}} ({{status}})"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 18,
      "title": "Backend Duration (p95)",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation, backend) (rate(s3proxy_backend_duration_seconds_bucket[5m])))",
          "legendFormat": "{{backend}} {{operation}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "table",
      "id": 19,
      "title": "Active Multipart Uploads",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (backend) (s3proxy_active_multipart_uploads)",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "backend", "desc": false }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "Value": "Uploads" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Uploads" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 10 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "id": 20,
      "title": "Manager Operations",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Manager Request Rate",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (operation, status) (rate(s3proxy_manager_requests_total[5m]))",
          "legendFormat": "{{operation}} ({{status}})"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "Manager Duration (p95)",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation, backend) (rate(s3proxy_manager_duration_seconds_bucket[5m])))",
          "legendFormat": "{{backend}} {{operation}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "row",
      "id": 23,
      "title": "Circuit Breaker & Degraded Mode",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "id": 24,
      "title": "Circuit Breaker State",
      "gridPos": { "x": 0, "y": 40, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "s3proxy_circuit_breaker_state",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "name": "Name",
              "Value": "State"
            },
            "indexByName": {
              "name": 0,
              "Value": 1
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Closed", "color": "green" } } },
                  { "type": "value", "options": { "1": { "text": "Open", "color": "red" } } },
                  { "type": "value", "options": { "2": { "text": "Half-Open", "color": "yellow" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 25,
      "title": "CB Transitions",
      "gridPos": { "x": 8, "y": 40, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (name, from, to) (rate(s3proxy_circuit_breaker_transitions_total[5m]))",
          "legendFormat": "{{name}}: {{from}} → {{to}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 26,
      "title": "Degraded Mode Ops",
      "gridPos": { "x": 16, "y": 40, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (op) (rate(s3proxy_degraded_reads_total[5m]))",
          "legendFormat": "reads {{op}}"
        },
        {
          "expr": "rate(s3proxy_degraded_cache_hits_total[5m])",
          "legendFormat": "cache hits"
        },
        {
          "expr": "sum by (op) (rate(s3proxy_degraded_write_rejections_total[5m]))",
          "legendFormat": "write rejections {{op}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "row",
      "id": 27,
      "title": "Replication",
      "gridPos": { "x": 0, "y": 48, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 28,
      "title": "Replication Pending",
      "gridPos": { "x": 0, "y": 49, "w": 5, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "s3proxy_replication_pending",
          "legendFormat": "pending"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 29,
      "title": "Copies Created",
      "gridPos": { "x": 5, "y": 49, "w": 5, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(s3proxy_replication_copies_created_total[5m])",
          "legendFormat": "copies/s"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 30,
      "title": "Replication Errors",
      "gridPos": { "x": 10, "y": 49, "w": 5, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(s3proxy_replication_errors_total[5m])",
          "legendFormat": "errors/s"
